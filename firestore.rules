rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      // Users can read their own data
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Users can create their own document on registration
      allow create: if request.auth != null && request.auth.uid == userId;
       
      // Users can update their own data (but NOT their role)
      allow update: if request.auth != null && request.auth.uid == userId
        && !(request.resource.data.role != resource.data.role);
      
      // No deleting user accounts
      allow delete: if false;
    }
    
    // ============================================
    // GROUPS COLLECTION
    // ============================================
    match /groups/{groupId} {
      // All authenticated users can read groups
      allow read: if request.auth != null;
      
      // Only Admins can create groups
      allow create: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
      
      // Only the creator can update the group
      allow update: if request.auth != null 
        && resource.data.createdBy == request.auth.uid;
      
      // Only Admins can delete groups
      allow delete: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    // ============================================
    // CONTRIBUTIONS COLLECTION
    // ============================================
    match /contributions/{contributionId} {
      // Members can read their own contributions
      // Treasurers and Admins can read ALL contributions
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Treasurer' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'
      );
      
      // Members can create their own contributions
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid;
      
      // Only Treasurers and Admins can update status (confirm/pending/missed)
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Treasurer' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'
      );
      
      // No deleting contributions
      allow delete: if false;
    }
    
    // ============================================
    // MEETINGS COLLECTION
    // ============================================
    match /meetings/{meetingId} {
      // All authenticated users can read meetings
      allow read: if request.auth != null;
      
      // Only Treasurers and Admins can create meetings
      allow create: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Treasurer' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'
      );
      
      // Only the creator can update meetings
      allow update: if request.auth != null 
        && resource.data.createdBy == request.auth.uid;
      
      // Only Admins can delete meetings
      allow delete: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    // ============================================
    // PAYOUTS COLLECTION
    // ============================================
    match /payouts/{payoutId} {
      // All authenticated users can read payouts
      allow read: if request.auth != null;

      // Only Admins and Treasurers can create/update payouts
      allow write: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Treasurer'
      );
    }

    // ============================================
    // MEMBERSHIPS COLLECTION
    // ============================================
    match /memberships/{membershipId} {
      // Users can read their own memberships
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;

      // System can create memberships when accepting invites
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;

      // No manual updates or deletes
      allow update, delete: if false;
    }

    // ============================================
    // INVITES COLLECTION
    // ============================================
    match /invites/{inviteId} {
      // Users can read invites sent to their email
      allow read: if request.auth != null && request.auth.token.email == resource.data.email;

      // Group admins can send invites for their groups
      allow create: if request.auth != null && request.resource.data.invitedBy == request.auth.uid;

      // Invited users can update to accept invites
      allow update: if request.auth != null && request.auth.token.email == resource.data.email;

      // No deleting invites
      allow delete: if false;
    }

    // ============================================
    // GROUP MEMBERS SUBCOLLECTION
    // ============================================
    match /groups/{groupId}/members/{memberId} {
      // All group members can read the members list
      allow read: if request.auth != null && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));

      // Admins can add members, or users can be added via invite acceptance
      allow create: if request.auth != null && (
        get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'admin' ||
        (request.resource.data.uid == request.auth.uid && request.resource.data.role == 'member')
      );

      // Admins can update member roles
      allow update: if request.auth != null &&
        get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'admin';

      // Admins can remove members
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    // ============================================
    // TRANSACTIONS COLLECTION (PAYMENTS)
    // ============================================
    match /transactions/{transactionId} {
      // Users can read their own transactions
      // Admins can read all transactions
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'
      );
      
      // System creates transactions via payment processing
      // Users can only create if they are the user
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending';
      
      // Only the system (via cloud functions/webhooks) can update transaction status
      // Users cannot modify transaction status directly
      allow update: if false;
      
      // No deleting transactions
      allow delete: if false;
    }

    // ============================================
    // PAYMENT PROOFS SUBCOLLECTION
    // ============================================
    match /transactions/{transactionId}/paymentProofs/{proofId} {
      // Users can read payment proofs for their own transactions
      // Admins can read all payment proofs
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/transactions/$(transactionId)).data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'
      );
      
      // Only the system can create payment proofs (via webhooks)
      allow create: if false;
      
      // No updates or deletes
      allow update, delete: if false;
    }

    // ============================================
    // WEBHOOK EVENTS COLLECTION (System Logs)
    // ============================================
    match /webhookEvents/{eventId} {
      // Only Admins can read webhook events for debugging
      allow read: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
      
      // Only the system can write webhook events
      allow write: if false;
      
      // No deletes
      allow delete: if false;
    }

    // ============================================
    // PAYMENT QUEUES COLLECTION (Async Processing)
    // ============================================
    match /paymentQueues/{queueId} {
      // Only Admins can read payment queues
      allow read: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
      
      // Only the system can manage payment queues
      allow write: if false;
    }
  }
}

// Payouts collection
match /payouts/{payoutId} {
  allow read: if request.auth != null;
  allow write: if request.auth != null && 
    (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Treasurer', 'Admin']);
}