{
  "hosting": {
    "public": "../frontend",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          }
        ]
      },
      {
        "source": "**/*.@(css|js)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/login",
        "destination": "/login.html",
        "type": 301
      },
      {
        "source": "/register",
        "destination": "/register.html",
        "type": 301
      }
    ]
  },
  "functions": {
    "source": "backend",
    "runtime": "nodejs18",
    "predeploy": []
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firebase/firestore.indexes.json"
  }
}
